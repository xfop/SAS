import { readFileSync } from 'fs';
import { parseTimetableHTML } from './src/parsers/timetableParser.js';
import { parseRecordHTML } from './src/parsers/recordParser.js';
import { getEligibleCourses, generateSchedules } from './src/scheduler/generator.js';

// Load academic plan
const academicPlan = JSON.parse(readFileSync('./src/data/academicPlan.json', 'utf-8'));
console.log('=== Academic Plan ===');
console.log(`Loaded ${Object.keys(academicPlan).length} courses\n`);

// Parse timetable
const timetableHTML = readFileSync('../timetable.html', 'utf-8');
const sections = parseTimetableHTML(timetableHTML);
console.log('=== Timetable Parsing ===');
console.log(`Found ${sections.length} sections\n`);

if (sections.length > 0) {
  console.log('First 5 sections:');
  sections.slice(0, 5).forEach((s, i) => {
    console.log(`\n${i + 1}. ${s.courseCode} - ${s.courseName}`);
    console.log(`   Section: ${s.section}, Instructor: ${s.instructor}`);
    console.log(`   Days:`, JSON.stringify(s.days, null, 2));
  });
} else {
  console.log('ERROR: No sections found! Check the HTML structure.');
}

// Parse student record
const recordHTML = readFileSync('../student record.html', 'utf-8');
const { passedCourses, allCourses } = parseRecordHTML(recordHTML);
console.log('\n=== Student Record Parsing ===');
console.log(`Found ${allCourses.length} courses in record`);
console.log(`Passed: ${passedCourses.length} courses`);
console.log('Passed courses:', passedCourses.join(', '));

// Get eligible courses
const eligibleCourses = getEligibleCourses(academicPlan, passedCourses, sections);
console.log('\n=== Eligible Courses ===');
console.log(`Student is eligible for ${eligibleCourses.length} courses:`);
eligibleCourses.forEach(code => {
  const course = academicPlan[code];
  const availableSections = sections.filter(s => s.courseCode === code);
  console.log(`  - ${code}: ${course?.name} (${availableSections.length} sections available)`);
});

// Generate schedules
const schedules = generateSchedules(academicPlan, eligibleCourses, sections);
console.log('\n=== Schedule Generation ===');
console.log(`Generated ${schedules.length} possible schedules`);

if (schedules.length > 0) {
  console.log('\nFirst schedule:');
  const first = schedules[0];
  console.log(`  Credits: ${first.totalCredits}, Courses: ${first.courseCount}`);
  first.sections.forEach(s => {
    console.log(`  - ${s.courseCode} ${s.section}: ${s.courseName}`);
    Object.entries(s.days).forEach(([day, slot]) => {
      if (slot) console.log(`      ${day}: ${slot.display}`);
    });
  });
}

import { readFileSync } from 'fs';
import { parseRecordHTML } from './src/parsers/recordParser.js';

const html = readFileSync('../student record.html', 'utf-8');
const { passedCourses, allCourses } = parseRecordHTML(html);

console.log('=== All Courses Found ===\n');

// Find STAT and CS289
const targetCourses = allCourses.filter(c =>
  c.courseCode.includes('STAT') || c.courseCode.includes('289')
);

console.log('STAT and CS289 courses:');
targetCourses.forEach(c => {
  console.log(`  ${c.courseCode}: grade="${c.grade}", passed=${c.passed}`);
});

console.log('\n=== Passed Courses ===');
console.log(passedCourses.join(', '));

console.log('\n=== NOT Passed (grade F or empty) ===');
const notPassed = allCourses.filter(c => !c.passed);
notPassed.forEach(c => {
  console.log(`  ${c.courseCode}: grade="${c.grade}"`);
});
